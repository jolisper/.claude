# Ignore everything by default
*

# Allowlist shareable files
!.gitignore
!CLAUDE.md
!README.md
!statusline.conf
!statusline-command.sh
statusline.local.conf

# Allowlist directories and their contents
!agents/
!agents/**
!skills/
!skills/**
!commands/
!commands/**
!scripts/
!scripts/**

# Re-ignore personal/generated files within allowed dirs
agents/*.bak
