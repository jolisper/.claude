# Ignore everything by default
*

# Allowlist shareable files
!.gitignore
!CLAUDE.md
!README.md
!settings.template.json

# Allowlist directories and their contents
!agents/
!agents/**
!skills/
!skills/**
!commands/
!commands/**
!scripts/
!scripts/**
!statusline/
!statusline/**

# Re-ignore local overrides within statusline/
statusline/statusline.local.conf

!docs/
!docs/**

# Re-ignore personal/generated files within allowed dirs
agents/*.bak

